###
# USER CONFIGURATION (REQUIRED)
# Copy this file to .env and fill in the values before running docker-compose
###

# ---------------------------------------------------------
# 1. Domain & Routing (Traefik)
# ---------------------------------------------------------
# The domain where the web interface will be accessible.
# If you DO NOT have a domain name, you can use a free sslip.io address based on your server's IP.
# Example: If your server IP is 1.2.3.4, set this to 1.2.3.4.sslip.io
PUBLIC_DOMAIN=localhost

# Email for Let's Encrypt SSL certificate generation
ACME_EMAIL=example@sample.com

# ---------------------------------------------------------
# 2. Discord Bot Credentials
# ---------------------------------------------------------
# From Discord Developer Portal -> Bot -> Token
BOT_TOKEN="your_discord_bot_token_here"

# ---------------------------------------------------------
# 3. Discord OAuth (For Web Login)
# ---------------------------------------------------------
# From Discord Developer Portal -> OAuth2 -> General
DISCORD_CLIENT_ID="your_client_id_here"
DISCORD_CLIENT_SECRET="your_client_secret_here"

# ---------------------------------------------------------
# 4. Web Security
# ---------------------------------------------------------
# Run "openssl rand -hex 32" to generate a secure secret
NEXTAUTH_SECRET="changeme"


# Shared secret for internal health checks between containers
INTERNAL_HEALTH_TOKEN="changeme"

# ---------------------------------------------------------
# 5. Database Setup
# ---------------------------------------------------------
# Choose a secure password for your PostgreSQL database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres


